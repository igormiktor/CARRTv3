# Lines starting with '#' are considered comments.

# Ignore any backup files.
*~
*.bak
~*
*.lck

# Ignore old files
*.old
*.old.*

# Ignore kate swap files
*.kate-swp

# Ignore any build directories
build*

# Ignore the schematic outputs
# *.pdf
# *.jpg
# Except the schematic PDF
# !schematics/"CARRTv3 Schematic.pdf"

# Compiled Object files
*.slo
*.lo
*.o

# Compiled Dynamic libraries
*.so
*.dylib

# Compiled Static libraries
*.lai
*.la
*.a

# Ignore any .xxx files
.*

# Ignore anything in a "Hold"
Hold

# Ignore contents of the support directory
support/*

# Ignore schematics backups
CARRTv3-backups

# Ignore VSCodeCount directories
.VSCodeCounter

